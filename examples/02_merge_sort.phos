fn merge(left: i64[], right: i64[]) -> i64[] {
    let mut result : i64[] = [];
    let mut i := 0;
    let mut j := 0;

    while i < len(left) && j < len(right) {
        if left[i] <= right[j] {
            result.push(left[i]);
            i = i + 1;
        } else {
            result.push(right[j]);
            j = j + 1;
        }
    }

    // Drain remaining left elements
    while i < len(left) {
        result.push(left[i]);
        i = i + 1;
    }

    // Drain remaining right elements
    while j < len(right) {
        result.push(right[j]);
        j = j + 1;
    }

    return result;
}

fn merge_sort(arr: i64[]) -> i64[] {
    let length := len(arr);
    if length <= 1 {
        return arr;
    }

    // Cast the float division back to an integer!
    let mid := (length / 2) as i64;

    // Manually slice the arrays
    let mut left : i64[] = [];
    let mut i := 0;
    while i < mid {
        left.push(arr[i]);
        i = i + 1;
    }

    let mut right : i64[] = [];
    let mut j := mid;
    while j < length {
        right.push(arr[j]);
        j = j + 1;
    }

    // Recursive calls and merge
    left = merge_sort(left);
    right = merge_sort(right);

    return merge(left, right);
}

let unsorted := [38, 27, 43, 3, 9, 82, 10];
print("Unsorted: ");
print(unsorted);
let sorted := merge_sort(unsorted);
print("Merge Sort Result:");
print(sorted);
